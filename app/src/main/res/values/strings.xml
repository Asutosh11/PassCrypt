    <string name="transfer_intro_1_short">Direct Android-to-Android transfer only.</string>
    <string name="transfer_intro_1_long">Your passwords never touch the internet. Data moves directly between Android devices via scanning (QR). For Apple users, use the specialized CSV export.</string>
    <string name="transfer_intro_2_title">Multi-Mode Backups</string>
    <string name="transfer_intro_2_short">Encrypted PDF or unencrypted CSV for iOS.</string>
    <string name="transfer_intro_2_long">"Choose your backup: A password-locked PDF for general safety, or a standard CSV for direct import into Apple's iCloud Keychain (iOS). Always handle these files with care."</string>
    <string name="transfer_intro_3_title">Trust but Verify</string>
    <string name="transfer_intro_3_short">The transfer protocol is open source.</string>
    <string name="transfer_intro_3_long">Every line of our transfer logic—from QR chunking to secure encryption—is available for public audit on GitHub. We hide nothing.</string>
    
