    <!-- Intro Section -->
    <string name="intro_title">What makes this app secure?</string>
    <string name="intro_collapse">Collapse</string>
    <string name="intro_expand">Expand</string>
    <string name="intro_storage_title">Local Encrypted Storage</string>
    <string name="intro_storage_short">All data is stored in a secure local database, locked by your device\'s Master Key.</string>
    <string name="intro_storage_long">By removing the \'Cloud\', we eliminate server-side breaches. Your \'Master Key\' is tied to your device credentials (Biometric or PIN). Without these credentials, the data remains a locked, unreadable file.</string>
    <string name="intro_network_title">Zero Network Access</string>
    <string name="intro_network_short">No internet permissions. Your data never leaves your device.</string>
    <string name="intro_network_long">You can verify it yourself: Settings → Apps → PassCrypt → Mobile data &amp; Wi-Fi. You\'ll see 0 B used.. PassCrypt does not request the INTERNET permission — making it impossible for the app to send your data anywhere.</string>
    <string name="intro_source_title">Open Source Transparency</string>
    <string name="intro_source_short">The code is public. Trust the math, not the developer.</string>
    <string name="intro_source_long">PassCrypt is Open Source. You can inspect the entire codebase yourself on GitHub to verify how we handle encryption and ensure there are no backdoors. [https://github.com/Asutosh11/PassCrypt](https://github.com/Asutosh11/PassCrypt)</string>
    <string name="intro_crypto_title">Military-Grade Encryption</string>
    <string name="intro_crypto_short">Your vault is secured using AES-256 encryption.</string>
    <string name="intro_crypto_long">Every byte of your data is scrambled using AES-256. Your device\'s secure credentials act as the \'Master Key\'. Without your specific identity, the data is mathematically impossible to read.</string>
    <string name="intro_transfer_header">Secure Vault Transfer</string>
    <string name="intro_transfer_short">Move data Android-to-Android via QR or local backups.</string>
    <string name="intro_transfer_long">Need to switch phones? You can move your vault directly between Android devices via encrypted QR chunks. For Apple users, use the CSV export. No cloud, no risk of interception.</string>
